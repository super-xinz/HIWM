# Required by config/chat_with_hiwm_mac.yaml and chat_with_qwen_omni_mac.yaml
# Create a key in Alibaba Cloud Model Studio (Bailian / DashScope), then paste
# it after the equals sign. Never commit the real key.
DASHSCOPE_API_KEY=

# Required only when runtime-control endpoints are exposed to non-loopback
# clients. Use a long random value and enter the same value as the Web UI
# access token; loopback-only macOS startup does not require it.
HIWM_RUNTIME_CONTROL_TOKEN=

# Optional local runtime overrides. The defaults are shown below.
# HIWM_CONFIG=config/chat_with_hiwm_mac.yaml
# HIWM_HOST=127.0.0.1
# HIWM_PORT=8283
